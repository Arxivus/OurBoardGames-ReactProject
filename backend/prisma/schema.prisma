generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Player {
  id           String         @id
  name         String         @unique
  ownedGames   Game[]         @relation("GameOwner")
  matchPlayers MatchPlayer[]
  wonMatches   Match[]        @relation("MatchWinner")  
}

model Game {
  id               String        @id
  name             String        @unique
  players          String
  avgTimeInMinutes Int
  imageUrl         String
  description      String?
  ownerId          String
  priceInRubles    Int

  owner            Player        @relation("GameOwner", fields: [ownerId], references: [id], onUpdate: Cascade, onDelete: Restrict)
  genres           GameGenre[]
  matches          Match[]
}

model Genre {
  id    Int         @id @default(autoincrement())
  name  String      @unique
  games GameGenre[]
}

model GameGenre {
  gameId  String
  genreId Int

  game   Game  @relation(fields: [gameId], references: [id], onDelete: Cascade)
  genre  Genre @relation(fields: [genreId], references: [id], onDelete: Restrict)

  @@id([gameId, genreId])
}

model Match {
  id         String        @id
  gameId     String
  winnerId   String
  players    MatchPlayer[]

  game       Game          @relation(fields: [gameId], references: [id], onUpdate: Cascade, onDelete: Restrict)
  winner     Player        @relation("MatchWinner", fields: [winnerId], references: [id], onUpdate: Cascade, onDelete: Restrict)
}

model MatchPlayer {
  matchId  String
  playerId String

  match    Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player   Player @relation(fields: [playerId], references: [id], onUpdate: Cascade, onDelete: Restrict)

  @@id([matchId, playerId])
}